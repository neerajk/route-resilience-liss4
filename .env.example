# Copy to .env (gitignored) and fill in. Loaded by the real-data fetchers.
# Bhoonidhi (LISS-IV via STAC + JWT)
BHOONIDHI_USER=
BHOONIDHI_PASS=
# HuggingFace (Clay v1.5 / DINOv3 weights download; DINOv3 timm id is non-gated)
HF_TOKEN=
# macOS MPS: allow CPU fallback for ops not yet on Metal
PYTORCH_ENABLE_MPS_FALLBACK=1
