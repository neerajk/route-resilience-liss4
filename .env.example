# Copy to .env (gitignored) and fill in. Loaded by the real-data fetchers.
# Bhoonidhi (LISS-IV via STAC + JWT)
BHOONIDHI_USER=
BHOONIDHI_PASS=
# HuggingFace (Clay v1.5 / DINOv3 weights download; DINOv3 timm id is non-gated)
HF_TOKEN=
# macOS MPS only: allow CPU fallback for ops not yet on Metal. Harmless/ignored on
# Windows + Linux (no MPS there). Setting env vars outside this file, per shell:
#   bash/zsh (macOS/Linux):  export PYTORCH_ENABLE_MPS_FALLBACK=1
#   PowerShell (Windows):    $env:PYTORCH_ENABLE_MPS_FALLBACK = "1"
PYTORCH_ENABLE_MPS_FALLBACK=1
